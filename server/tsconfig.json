{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",          // This is the key change
    "moduleResolution": "NodeNext", // Ensures imports work correctly
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}